# Google OAuth (generated once via OAuth Playground, long-lived refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Analytics 4 numeric property ID (e.g. 123456789)
GA4_PROPERTY_ID=

# Search Console site URL (e.g. https://www.potastudio.com/ or sc-domain:potastudio.com)
GSC_SITE_URL=

# Shared secret protecting the /api/insights/* and /api/indexnow endpoints
INSIGHTS_API_SECRET=

# IndexNow key — must also be served as a static file at /{INDEXNOW_KEY}.txt
INDEXNOW_KEY=
